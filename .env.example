# Copy this file to .env and fill in real values. Never commit .env.

# ── PostgreSQL credentials ─────────────────────────────────
POSTGRES_USER=buguard
POSTGRES_PASSWORD=change_me
POSTGRES_DB=darkatlas_assets

# ── Database connection string ─────────────────────────────
# Use this value when running the app directly on your host (e.g. uvicorn).
# When running via docker compose, the app service overrides this to use the
# "db" host automatically — you do not need to change it for compose.
DATABASE_URL=postgresql://buguard:change_me@localhost:5432/darkatlas_assets

# ── LLM provider ───────────────────────────────────────────
# Gemini is called through its OpenAI-compatible endpoint (see app/ai/llm.py).
GEMINI_API_KEY=your_api_key_here
